{
  "name": "yyladminweb",
  "version": "4.0.0",
  "description": "Minimalist background management system based on ThinkPHP and Vue",
  "keywords": [
    "yylAdmin",
    "yylAdminWeb",
    "php",
    "vue",
    "thinkphp",
    "element-plus"
  ],
  "author": "https://github.com/skyselang/",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite serve --mode development",
    "build:prod": "vite build --mode production",
    "start:local-stack": "node ./scripts/start-local-stack.mjs",
    "check:local-stack": "node ./scripts/check-local-stack.mjs",
    "validate:admin-next-dev": "node ./scripts/validate-admin-next-env.mjs admin-next-dev",
    "validate:admin-next-local": "node ./scripts/validate-admin-next-env.mjs admin-next-local",
    "validate:admin-next-online": "node ./scripts/validate-admin-next-env.mjs admin-next-online",
    "release:preflight:admin-next-dev": "node ./scripts/release-preflight-admin-next.mjs admin-next-dev",
    "release:preflight:admin-next-local": "node ./scripts/release-preflight-admin-next.mjs admin-next-local",
    "release:preflight:admin-next-online": "node ./scripts/release-preflight-admin-next.mjs admin-next-online",
    "report:admin-next-coverage": "node ./scripts/build-admin-next-coverage.mjs",
    "report:admin-next-focus": "node ./scripts/build-admin-next-focus-report.mjs",
    "build:admin-next-dev": "npm run validate:admin-next-dev && node ./scripts/clean-admin-next-dev.mjs && vite build --mode admin-next-dev",
    "build:admin-next-local": "npm run validate:admin-next-local && node ./scripts/clean-admin-next-local.mjs && vite build --mode admin-next-local",
    "build:admin-next-online": "npm run validate:admin-next-online && vite build --mode admin-next-online",
    "build:stage": "vite build --mode staging",
    "audit:admin-next-dev": "node ./scripts/run-admin-audit.mjs /admin-next-dev/",
    "audit:admin-next": "node ./scripts/run-admin-audit.mjs /admin-next/",
    "audit:full-stack": "node ./scripts/run-full-stack-smoke.mjs",
    "build-and-audit:admin-next-local": "npm run check:local-stack && npm run build:admin-next-local && npm run audit:admin-next",
    "prepare-build-and-audit:admin-next-local": "npm run start:local-stack && npm run build-and-audit:admin-next-local",
    "preview:prod": "vite preview --mode production",
    "preview:stage": "vite preview --mode staging",
    "lint": "eslint --ext .js,.cjs,.vue ./src",
    "format": "prettier --write \"**/*.{js,cjs,json,css,less,scss,vue,html,md}\""
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^4.6.2",
    "@vueuse/core": "^10.11.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "5.1.10",
    "@wangeditor/plugin-upload-attachment": "^1.1.0",
    "axios": "^1.7.3",
    "clipboardy": "^4.0.0",
    "crypto-js": "^4.2.0",
    "default-passive-events": "^2.0.0",
    "echarts": "^5.5.1",
    "element-plus": "^2.9.1",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "path-to-regexp": "^6.2.2",
    "pinia": "^2.2.0",
    "terser": "^5.31.3",
    "vue": "^3.4.35",
    "vue-i18n": "^9.13.1",
    "vue-router": "^4.4.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-vue": "^9.27.0",
    "fast-glob": "^3.3.2",
    "prettier": "^2.8.8",
    "sass": "^1.77.8",
    "unocss": "^0.58.9",
    "unplugin-auto-import": "^0.15.3",
    "unplugin-icons": "^0.16.6",
    "unplugin-vue-components": "^0.24.1",
    "vite": "^5.3.5",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitee.com/skyselang/yylAdminWeb.git"
  },
  "bugs": {
    "url": "https://gitee.com/skyselang/yylAdminWeb/issues"
  },
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=8.19.0"
  }
}
