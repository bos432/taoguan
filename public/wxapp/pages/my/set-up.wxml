<view class="{{['data-v-e7ed8ac6','ui-theme-'+($store.state.setting&&$store.state.setting.system&&$store.state.setting.system.ui_theme_style||'origin')]}}"><view class="settings-page data-v-e7ed8ac6"><view class="hero-card data-v-e7ed8ac6"><view class="hero-badge data-v-e7ed8ac6">账号设置</view><view class="hero-profile data-v-e7ed8ac6"><image class="hero-avatar data-v-e7ed8ac6" src="{{displayAvatarUrl}}" mode="aspectFill"></image><view class="hero-userinfo data-v-e7ed8ac6"><view class="hero-title data-v-e7ed8ac6">{{displayName}}</view><view class="hero-subtitle data-v-e7ed8ac6">{{displayPhone}}</view></view></view></view><view class="section-card data-v-e7ed8ac6"><view class="section-head data-v-e7ed8ac6"><view class="section-title data-v-e7ed8ac6">基础信息</view><view class="section-tip data-v-e7ed8ac6">点击对应项目可修改</view></view><view class="setting-list data-v-e7ed8ac6"><view data-event-opts="{{[['tap',[['editAvatar',['$event']]]]]}}" class="setting-item data-v-e7ed8ac6" bindtap="__e"><view class="setting-main data-v-e7ed8ac6"><view class="setting-label data-v-e7ed8ac6">头像</view><view class="setting-desc data-v-e7ed8ac6">上传新的个人头像</view></view><view class="setting-action data-v-e7ed8ac6"><image class="setting-avatar data-v-e7ed8ac6" src="{{displayAvatarUrl}}" mode="aspectFill"></image></view></view><view data-event-opts="{{[['tap',[['editNameTap',['$event']]]]]}}" class="setting-item data-v-e7ed8ac6" bindtap="__e"><view class="setting-main data-v-e7ed8ac6"><view class="setting-label data-v-e7ed8ac6">姓名</view><view class="setting-desc data-v-e7ed8ac6">用于订单和资料展示</view></view><view class="setting-action text-action data-v-e7ed8ac6">{{''+(userInfo.name||"点击设置")+''}}</view></view><view class="setting-item data-v-e7ed8ac6"><view class="setting-main data-v-e7ed8ac6"><view class="setting-label data-v-e7ed8ac6">性别</view><view class="setting-desc data-v-e7ed8ac6">可在这里更新个人资料</view></view><view class="setting-action text-action data-v-e7ed8ac6"><picker value="{{userInfo.gender||0}}" range="{{sexPicker}}" data-event-opts="{{[['change',[['sexPickerChange',['$event']]]]]}}" bindchange="__e" class="data-v-e7ed8ac6"><view class="picker-value data-v-e7ed8ac6">{{''+(sexPicker[userInfo.gender||0]||"保密")+''}}</view></picker></view></view><view class="setting-item static-item data-v-e7ed8ac6"><view class="setting-main data-v-e7ed8ac6"><view class="setting-label data-v-e7ed8ac6">手机号</view><view class="setting-desc data-v-e7ed8ac6">当前绑定的登录手机号</view></view><view class="setting-action text-action data-v-e7ed8ac6">{{''+displayPhone+''}}</view></view></view></view><view class="section-card data-v-e7ed8ac6"><view class="section-head data-v-e7ed8ac6"><view class="section-title data-v-e7ed8ac6">协议与连接</view><view class="section-tip data-v-e7ed8ac6">查看协议与当前接口地址</view></view><view class="setting-list data-v-e7ed8ac6"><view data-event-opts="{{[['tap',[['openAccordCenter',['$event']]]]]}}" class="setting-item data-v-e7ed8ac6" bindtap="__e"><view class="setting-main data-v-e7ed8ac6"><view class="setting-label data-v-e7ed8ac6">协议中心</view><view class="setting-desc data-v-e7ed8ac6">查看免责声明、用户协议、隐私政策和售后说明</view></view><view class="setting-action text-action data-v-e7ed8ac6">查看</view></view><view data-event-opts="{{[['tap',[['copyApiRoot',['$event']]]]]}}" class="setting-item data-v-e7ed8ac6" bindtap="__e"><view class="setting-main data-v-e7ed8ac6"><view class="setting-label data-v-e7ed8ac6">当前接口地址</view><view class="setting-desc data-v-e7ed8ac6">{{displayApiRoot}}</view></view><view class="setting-action text-action data-v-e7ed8ac6">复制</view></view></view></view><view class="action-area data-v-e7ed8ac6"><button data-event-opts="{{[['tap',[['outLogin',['$event']]]]]}}" class="logout-btn data-v-e7ed8ac6" bindtap="__e">退出登录</button></view></view></view>