<view class="register"><bar-title vue-id="953665b2-1" bgColor="bg-grey-register" isBack="{{true}}" bind:__l="__l" vue-slots="{{['content']}}"><view slot="content"></view></bar-title><view class="content"><view class="header"><image src="{{logoImage}}"></image></view><view class="login-tabs"><block wx:for="{{loginModes}}" wx:for-item="item" wx:for-index="__i0__" wx:key="code"><view data-event-opts="{{[['tap',[['switchLoginMode',['$0'],[[['loginModes','code',item.code,'code']]]]]]]}}" class="{{['login-tab',loginMode===item.code?'is-active':'']}}" bindtap="__e"><text>{{item.label}}</text></view></block></view><view class="mode-tip">{{currentModeTip}}</view><block wx:if="{{loginMode==='code'}}"><view class="main"><w-input bind:input="__e" vue-id="953665b2-2" type="text" maxlength="11" placeholder="{{text.phonePlaceholder}}" value="{{phoneData}}" data-event-opts="{{[['^input',[['__set_model',['','phoneData','$event',[]]]]]]}}" bind:__l="__l"></w-input><w-input class="vue-ref" vue-id="953665b2-3" type="number" maxlength="6" placeholder="{{text.codePlaceholder}}" isShowCode="{{true}}" data-ref="runCode" value="{{verCode}}" data-event-opts="{{[['^setCode',[['getVerCode']]],['^input',[['__set_model',['','verCode','$event',[]]]]]]}}" bind:setCode="__e" bind:input="__e" bind:__l="__l"></w-input><w-button class="wbutton" vue-id="953665b2-4" text="{{text.codeLoginButton}}" rotate="{{isRotate}}" bgColor="linear-gradient(45deg, #0081ff,#1cbbb4)" data-event-opts="{{[['tap',[['startCodeLogin']]]]}}" bindtap="__e" bind:__l="__l"></w-button></view></block><block wx:else><block wx:if="{{loginMode==='wechat'}}"><view class="main wechat-panel"><view class="wechat-hero"><text class="cuIcon-weixin wechat-icon"></text><view class="wechat-title">{{text.wechatTitle}}</view><view class="wechat-desc">{{text.wechatDesc}}</view></view><button class="wechat-login-btn" open-type="getPhoneNumber" data-event-opts="{{[['getphonenumber',[['onGetPhoneNumber',['$event']]]]]}}" bindgetphonenumber="__e">{{''+text.wechatButton+''}}</button></view></block><block wx:else><view class="main"><view class="plain-input-wrap"><input class="plain-input" type="text" placeholder="{{text.accountPlaceholder}}" data-event-opts="{{[['input',[['__set_model',['','accountData','$event',[]]]]]]}}" value="{{accountData}}" bindinput="__e"/></view><view class="plain-input-wrap"><input class="plain-input" password="{{true}}" placeholder="{{text.passwordPlaceholder}}" data-event-opts="{{[['input',[['__set_model',['','passwordData','$event',[]]]]]]}}" value="{{passwordData}}" bindinput="__e"/></view><w-button class="wbutton" vue-id="953665b2-5" text="{{text.accountLoginButton}}" rotate="{{isRotate}}" bgColor="linear-gradient(45deg, #0081ff,#1cbbb4)" data-event-opts="{{[['tap',[['startAccountLogin']]]]}}" bindtap="__e" bind:__l="__l"></w-button></view></block></block><view class="agreement-footer"><view data-event-opts="{{[['tap',[['isShowAgree',['$event']]]]]}}" class="agreement-check" bindtap="__e"><text class="{{['cuIcon',showAgree?'cuIcon-radiobox text-blue':'cuIcon-round text-gray']}}"></text><text class="agreement-check-text">{{text.readAgree}}</text></view><view class="agreement-links"><text data-event-opts="{{[['tap',[['openAccordCenter',['$event']]]]]}}" class="agreement-link" bindtap="__e">{{text.accordCenter}}</text><text data-event-opts="{{[['tap',[['openAccord',['user_agreement']]]]]}}" class="agreement-link" bindtap="__e">{{text.userAgreement}}</text><text data-event-opts="{{[['tap',[['openAccord',['privacy_policy']]]]]}}" class="agreement-link" bindtap="__e">{{text.privacyPolicy}}</text></view></view></view></view>