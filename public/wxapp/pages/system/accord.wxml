<view class="accord-page"><block wx:if="{{info.name}}"><view class="accord-head"><view class="accord-title">{{info.name}}</view><block wx:if="{{info.desc}}"><view class="accord-desc">{{info.desc}}</view></block></view></block><view class="accord-content"><view class="font-view"><rich-text nodes="{{info.content||''}}"></rich-text></view></view><view class="{{['cu-load',isLoad?'loading':info.content?'':'over']}}"></view></view>