g" data-url="{{item.file_url}}" data-event-opts="{{[['tap',[['viewImage',['$event']]]]]}}" bindtap="__e"><image src="{{item.file_url}}" mode="aspectFill"></image><view class="cu-tag bg-red" data-id="{{item.file_id}}" data-event-opts="{{[['tap',[['delImg',['$event']]]]]}}" catchtap="__e"><text class="cuIcon-close"></text></view></view></block><block wx:if="{{$root.g0}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="solids" bindtap="__e"><text class="cuIcon-cameraadd"></text></view></block></view></view><block wx:if="{{info.refund_status>=1}}"><view class="cu-form-group"><view class="title">售后状态</view><block wx:if="{{info.refund_status==1}}"><view>待审核</view></block><block wx:else><block wx:if="{{info.refund_status==2}}"><view>{{''+(info_data.refund_type==1?"已退款":"待退货")+''}}</view></block><block wx:else><block wx:if="{{info.refund_status==3}}"><view>拒绝申请</view></block><block wx:else><block wx:if="{{info.refund_status==4}}"><view>已退款</view></block></block></block></block></view></block><block wx:if="{{info.refund_status==3}}"><view class="cu-form-group"><view class="title">拒绝原因</view><view class="title">{{info.refund_reason}}</view></view></block><block wx:if="{{info.refund_status==2&&info_data.refund_type==2}}"><view class="cu-form-group"><view class="title">{{"收货人："+info.refund_consignee}}</view><button data-event-opts="{{[['tap',[['str_copy',['$0'],['info.refund_consignee']]]]]}}" class="cu-btn sm line-black" style="width:60px;" bindtap="__e">复制</button></view></block><block wx:if="{{info.refund_status==2&&info_data.refund_type==2}}"><view class="cu-form-group"><view class="title">{{"联系电话："+info.refund_phone}}</view><button data-event-opts="{{[['tap',[['str_copy',['$0'],['info.refund_phone']]]]]}}" class="cu-btn sm line-black" style="width:60px;" bindtap="__e">复制</button></view></block><block wx:if="{{info.refund_status==2&&info_data.refund_type==2}}"><view class="cu-form-group"><view class="title">{{"收货地址："+info.refund_address}}</view><button data-event-opts="{{[['tap',[['str_copy',['$0'],['info.refund_address']]]]]}}" class="cu-btn sm line-black" style="width:60px;" bindtap="__e">复制</button></view></block><block wx:if="{{info.refund_status==2&&info_data.refund_type==2}}"><view class="cu-form-group"><view class="title">快递公司：</view><my-picker bind:input="__e" vue-id="58840b1b-5" options="{{info.delivery_list}}" placeholder="请选择快递公司" value="{{info.refund_delivery_id}}" data-event-opts="{{[['^input',[['__set_model',['$0','refund_delivery_id','$event',[]],['info']]]]]}}" bind:__l="__l"></my-picker></view></block><block wx:if="{{info.refund_status==2&&info_data.refund_type==2}}"><view class="cu-form-group"><view class="title">快递单号：</view><input placeholder="请输入快递单号" data-event-opts="{{[['input',[['__set_model',['$0','refund_express','$event',[]],['info']]]]]}}" value="{{info.refund_express}}" bindinput="__e"/></view></block><view class="bg-white zaiui-foot-padding-bottom margin-top"><view class="flex flex-direction"><block wx:if="{{info.refund_status<=0}}"><button data-event-opts="{{[['tap',[['submitBtn',['$event']]]]]}}" class="cu-btn bg-red" bindtap="__e">申请售后</button></block><block wx:else><block wx:if="{{info.refund_status==2&&info_data.refund_type==2}}"><button data-event-opts="{{[['tap',[['submitDeliveryBtn',['$event']]]]]}}" class="cu-btn bg-red" bindtap="__e">提交发货</button></block><block wx:else><button data-event-opts="{{[['tap',[['backBtn',['$event']]]]]}}" class="cu-btn bg-red" bindtap="__e">返回</button></block></block></view></view></view></block><view class="{{['cu-load',isLoad?'loading':info.id?'':'over']}}"></view></view>